<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}Sebo Diaz</title>
  {%- if description %}
  <meta name="description" content="{{ description }}">
  {%- endif %}
  <link rel="icon" type="image/png" href="/images/favicons/favicon-96x96.png" sizes="96x96">
  <link rel="icon" type="image/svg+xml" href="/images/favicons/favicon.svg">
  <link rel="shortcut icon" href="/images/favicons/favicon.ico">
  <link rel="apple-touch-icon" sizes="180x180" href="/images/favicons/apple-touch-icon.png">
  <link rel="manifest" href="/images/favicons/site.webmanifest">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {%- if prose %}
  <link href="https://fonts.googleapis.com/css2?family=Audiowide&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Serif:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  {%- else %}
  <link href="https://fonts.googleapis.com/css2?family=Audiowide&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  {%- endif %}
  {%- if math %}
  <link rel="stylesheet" href="/css/katex/katex.min.css">
  {%- endif %}
  <link rel="stylesheet" href="/css/style.css">
  <meta name="theme-color" content="#16102b">
</head>

<body>
  <header class="site-header">
    <nav class="site-nav">
      <a class="site-name" href="/">Sebo Diaz</a>
      <div class="nav-links">
        <a href="/notes/">notes</a>
        <a href="/projects/">projects</a>
        <a href="/cv/">cv</a>
      </div>
    </nav>
  </header>

  <main class="page">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <p>&copy; 2026 Sebastian Diaz</p>
  </footer>

  <div id="lightbox" class="lightbox" hidden>
    <button class="lightbox-close" aria-label="Close">&times;</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="">
    <div id="lightbox-caption" class="lightbox-caption"></div>
  </div>

  <script src="/js/site.js" defer></script>
</body>

</html>
