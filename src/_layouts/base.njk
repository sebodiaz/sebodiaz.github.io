<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}Sebo Diaz</title>
  {%- if description %}
  <meta name="description" content="{{ description }}">
  {%- endif %}
  <link rel="icon" type="image/png" href="/images/favicons/favicon-96x96.png" sizes="96x96">
  <link rel="icon" type="image/svg+xml" href="/images/favicons/favicon.svg">
  <link rel="shortcut icon" href="/images/favicons/favicon.ico">
  <link rel="apple-touch-icon" sizes="180x180" href="/images/favicons/apple-touch-icon.png">
  <link rel="manifest" href="/images/favicons/site.webmanifest">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {%- if prose %}
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Serif:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  {%- else %}
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  {%- endif %}
  {%- if math %}
  <link rel="stylesheet" href="/css/katex/katex.min.css">
  {%- endif %}
  <link rel="stylesheet" href="/css/style.css">
  <script>
    // Set theme before first paint to avoid a flash of the wrong scheme
    (function () {
      var stored = localStorage.getItem("theme");
      var theme = stored || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
      document.documentElement.setAttribute("data-theme", theme);
    })();
  </script>
</head>

<body>
  <div class="hall-glow" aria-hidden="true"></div>
  <div class="hallway" aria-hidden="true">
    <svg viewBox="0 0 100 100" preserveAspectRatio="none" fill="none" stroke-width="1" width="100%" height="100%">
      <defs>
        <radialGradient id="vanish" gradientUnits="userSpaceOnUse" cx="50" cy="50" r="76">
          <stop offset="0" class="vp-core" />
          <stop offset="0.3" class="vp-mid" />
          <stop offset="1" class="vp-edge" />
        </radialGradient>
      </defs>
      <g stroke="url(#vanish)" vector-effect="non-scaling-stroke">
      <rect class="ring" x="8.0" y="8.0" width="84.0" height="84.0" />
      <rect class="ring" x="14.72" y="14.72" width="70.56" height="70.56" />
      <rect class="ring" x="20.36" y="20.36" width="59.27" height="59.27" />
      <rect class="ring" x="25.11" y="25.11" width="49.79" height="49.79" />
      <rect class="ring" x="29.09" y="29.09" width="41.82" height="41.82" />
      <rect class="ring" x="32.44" y="32.44" width="35.13" height="35.13" />
      <rect class="ring" x="35.24" y="35.24" width="29.51" height="29.51" />
      <rect class="ring" x="37.61" y="37.61" width="24.79" height="24.79" />
      <rect class="ring" x="39.59" y="39.59" width="20.82" height="20.82" />
      <rect class="ring" x="41.26" y="41.26" width="17.49" height="17.49" />
      <rect class="ring" x="42.66" y="42.66" width="14.69" height="14.69" />
      <rect class="ring" x="43.83" y="43.83" width="12.34" height="12.34" />
      <line x1="0" y1="0" x2="50" y2="50" />
      <line x1="100" y1="0" x2="50" y2="50" />
      <line x1="0" y1="100" x2="50" y2="50" />
      <line x1="100" y1="100" x2="50" y2="50" />
      <line x1="0" y1="50" x2="50" y2="50" />
      <line x1="100" y1="50" x2="50" y2="50" />
      </g>
    </svg>
  </div>
  <header class="site-header">
    <nav class="site-nav">
      <a class="site-name" href="/" aria-label="Sebo Diaz — home">sebo@mit:~$<span class="cursor" aria-hidden="true">&#9608;</span></a>
      <div class="nav-links">
        <a href="/notes/">notes</a>
        <a href="/projects/">projects</a>
        <a href="/cv/">cv</a>
        <button id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
          <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
      </div>
    </nav>
  </header>

  <main class="page">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <p>&copy; 2026 Sebastian Diaz</p>
  </footer>

  <div id="lightbox" class="lightbox" hidden>
    <button class="lightbox-close" aria-label="Close">&times;</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="">
    <div id="lightbox-caption" class="lightbox-caption"></div>
  </div>

  <script src="/js/site.js" defer></script>
</body>

</html>
