<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Sebo Diaz</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@0.9.4/css/bulma.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,400;0,700;1,400&family=Nunito:wght@400;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" href="../../images/favicons/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="../../images/favicons/favicon.svg" />
  <link rel="shortcut icon" href="../../images/favicons/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="../../images/favicons/apple-touch-icon.png" />
  <link rel="stylesheet" href="../../styles.css">

  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlightjs-line-numbers.js/2.8.0/highlightjs-line-numbers.min.js"></script>

  <script>
    MathJax = {
      tex: {
        inlineMath: [['$', '$'], ['\\(', '\\)']],
        displayMath: [['$$', '$$'], ['\\[', '\\]']],
        packages: {'[+]': ['ams']},
        tags: 'ams',
        macros: {
          R: '\\mathbb{R}',
          E: '\\mathbb{E}',
          N: '\\mathbb{N}',
          Z: '\\mathbb{Z}',
          norm: ['\\left\\lVert #1 \\right\\rVert', 1],
          abs:  ['\\left\\lvert #1 \\right\\rvert', 1],
          inner: ['\\langle #1,\\, #2 \\rangle', 2],
        }
      },
      options: {
        skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre'],
      }
    };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" id="MathJax-script" async></script>

  <style>
    .note-body {
      font-family: 'Merriweather', Georgia, serif;
      font-size: 1rem;
      line-height: 1.85;
      color: #2d2d2d;
      max-width: 720px;
      margin: 0 auto;
    }

    .note-title {
      font-family: 'Merriweather', serif;
      font-size: 2rem;
      font-weight: 700;
      line-height: 1.3;
      margin-bottom: 0.5rem;
    }

    .note-meta {
      font-family: 'Nunito', sans-serif;
      font-size: 0.85rem;
      color: #888;
      margin-bottom: 2rem;
    }

    .note-tag {
      font-size: 0.75rem;
      background: #f0f0f0;
      border-radius: 4px;
      padding: 1px 7px;
      color: #555;
      margin-right: 4px;
    }

    .note-body h2 {
      font-family: 'Merriweather', serif;
      font-size: 1.35rem;
      font-weight: 700;
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
      border-bottom: 1px solid #eee;
      padding-bottom: 0.3rem;
    }

    .note-body h3 {
      font-family: 'Merriweather', serif;
      font-size: 1.1rem;
      font-weight: 700;
      margin-top: 1.75rem;
      margin-bottom: 0.5rem;
    }

    .note-body p {
      margin-bottom: 1.25rem;
    }

    .note-body a {
      color: #3273dc;
      text-decoration: none;
    }
    .note-body a:hover {
      text-decoration: underline;
    }

    .note-body ul, .note-body ol {
      margin-left: 1.5rem;
      margin-bottom: 1.25rem;
    }

    .note-body .MJX-TEX {
      font-size: 1.05em;
    }

    .hljs            { background: #f8f8f8; color: #333; }
    .hljs-keyword,
    .hljs-built_in   { color: #008000; font-weight: bold; }
    .hljs-string,
    .hljs-doctag     { color: #ba2121; }
    .hljs-comment    { color: #408080; font-style: italic; }
    .hljs-number,
    .hljs-literal    { color: #666666; }
    .hljs-operator   { color: #666666; }
    .hljs-meta       { color: #aa22ff; font-weight: bold; }
    .hljs-title.function_,
    .hljs-title.class_ { color: #000080; font-weight: bold; }
    .hljs-variable,
    .hljs-params     { color: #333; }

    .note-body pre {
      background: #f8f8f8;
      border-radius: 4px;
      padding: 0;
      overflow-x: auto;
      font-size: 0.875rem;
      line-height: 1.6;
      margin-bottom: 1.25rem;
      border: 1px solid #d8d8d8;
      font-family: 'Inconsolata', 'Fira Mono', 'Courier New', monospace;
    }

    .note-body pre code.hljs {
      padding: 0.7rem 1rem;
      background: transparent;
      display: block;
    }

    table.hljs-ln {
      width: 100%;
      border-collapse: collapse;
    }

    td.hljs-ln-numbers {
      text-align: right;
      padding: 0 0.75rem;
      color: #aaa;
      background: #efefef;
      border-right: 1px solid #d0d0d0;
      user-select: none;
      vertical-align: top;
      min-width: 2.2em;
    }

    td.hljs-ln-code {
      padding: 0 0 0 1rem;
    }

    tr:first-child td.hljs-ln-numbers { border-radius: 3px 0 0 0; padding-top: 0.7rem; }
    tr:last-child  td.hljs-ln-numbers { border-radius: 0 0 0 3px; padding-bottom: 0.7rem; }
    tr:first-child td.hljs-ln-code    { padding-top: 0.7rem; }
    tr:last-child  td.hljs-ln-code    { padding-bottom: 0.7rem; }

    .note-body code:not(pre code) {
      background: #f0f0f0;
      border-radius: 3px;
      padding: 1px 5px;
      font-size: 0.875em;
      color: #c0392b;
      font-family: 'Inconsolata', 'Fira Mono', monospace;
    }

    .callout {
      border-left: 4px solid #b5b5b5;
      background: #fafafa;
      padding: 0.9rem 1.2rem;
      margin: 1.5rem 0;
      border-radius: 0 6px 6px 0;
      font-size: 0.95rem;
    }

    .callout.definition { border-left-color: #3273dc; }
    .callout.theorem    { border-left-color: #23d160; }
    .callout.remark     { border-left-color: #ffdd57; }
    .callout.warning    { border-left-color: #ff3860; }

    .callout-label {
      font-family: 'Nunito', sans-serif;
      font-weight: 700;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 0.4rem;
      color: #555;
    }

    .note-figure {
      text-align: center;
      margin: 2rem 0;
    }
    .note-figure img {
      max-width: 100%;
      border-radius: 6px;
    }
    .note-figure figcaption {
      font-family: 'Nunito', sans-serif;
      font-size: 0.85rem;
      color: #777;
      margin-top: 0.5rem;
    }

    .back-nav {
      margin-bottom: 2.5rem;
    }
  </style>
</head>

<body>
  <section class="section">
    <div class="main-container">

      <div class="back-nav">
        <a href="../" class="button is-light is-small">
          <span class="icon"><i class="fas fa-arrow-left"></i></span>
          <span>All Notes</span>
        </a>
      </div>

      <div class="note-body">

        <h1 class="note-title">{{ title | safe }}</h1>
        <div class="note-meta">
          {{ displayDate }}
          {%- if tags %}
          &nbsp;&middot;&nbsp;
          {%- for tag in tags %}
          <span class="note-tag">{{ tag }}</span>
          {%- endfor %}
          {%- endif %}
        </div>

        {{ content | safe }}

      </div>
    </div>
  </section>

  <script>
    hljs.highlightAll();
    hljs.initLineNumbersOnLoad();
  </script>
</body>

</html>
